@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <h2>Admin Dashboard</h2>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <h5 class="card-title">Total Workers</h5>
                    <h2>@ViewBag.TotalWorkers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <h5 class="card-title">Total Clients</h5>
                    <h2>@ViewBag.TotalClients</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <h5 class="card-title">Total Bookings</h5>
                    <h2>@ViewBag.TotalBookings</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <h5 class="card-title">Total Earnings</h5>
                    <h2>$@ViewBag.TotalEarnings</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Manage Hourly Rates</h5>
                    <p class="card-text">Set and update hourly rates for workers by skill.</p>
                    <a href="@Url.Action("ManageRates")" class="btn btn-primary">Manage Rates</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Manage Bookings</h5>
                    <p class="card-text">Approve, confirm, or cancel bookings.</p>
                    <a href="@Url.Action("ManageBookings")" class="btn btn-primary">Manage Bookings</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Generate Report</h5>
                    <p class="card-text">View earnings and booking reports.</p>
                    <a href="@Url.Action("GenerateReport")" class="btn btn-primary">Generate Report</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mt-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Manage Admins</h5>
                    <p class="card-text">Create and review admin login access.</p>
                    <a href="@Url.Action("ManageAdmins")" class="btn btn-primary">Manage Admins</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <h5 class="card-title">Active Jobs</h5>
                    <h2>@ViewBag.ActiveBookings</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <h5 class="card-title">Online Collected</h5>
                    <h2>$@ViewBag.AmountPaidOnline?.ToString("F2")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <h5 class="card-title">Paid to Workers</h5>
                    <h2>$@ViewBag.AmountPaidToWorkers?.ToString("F2")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card metric-card">
                <div class="card-body">
                    <h5 class="card-title">Outstanding</h5>
                    <h2>$@ViewBag.OutstandingBalance?.ToString("F2")</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="page-header">
        <h2>Analytics</h2>
        <p class="mb-1">Total bookings: @ViewBag.TotalBookings</p>
        <p class="mb-1">Completed revenue: $@ViewBag.TotalEarnings?.ToString("F2")</p>
        <p class="mb-0">Active workers: @ViewBag.TotalWorkers</p>
    </div>

    @if (ViewBag.TopSkills is List<string> topSkills && topSkills.Any())
    {
        <div class="alert alert-light border">
            <strong>Top demand:</strong> @string.Join(", ", topSkills)
        </div>
    }
</div>
