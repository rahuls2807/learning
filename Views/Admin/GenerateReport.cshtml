@model IEnumerable<WorkerBookingSystem.Models.Booking>

@{
    ViewData["Title"] = "Generate Report";
}

<div class="container mt-5">
    <h2>Earnings Report</h2>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100">Generate Report</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">Total Bookings</h5>
                    <h2>@ViewBag.TotalBookings</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Completed</h5>
                    <h2>@ViewBag.CompletedBookings</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Wages</h5>
                    <h2>$@ViewBag.TotalWages?.ToString("F2")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Period</h5>
                    <p class="card-text small">@ViewBag.StartDate?.ToString("MMM dd") - @ViewBag.EndDate?.ToString("MMM dd")</p>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <h4>Booking Details</h4>
        <div class="table-responsive">
            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Client</th>
                        <th>Worker</th>
                        <th>Date</th>
                        <th>Duration</th>
                        <th>Task</th>
                        <th>Client Pays</th>
                        <th>Worker Pay</th>
                        <th>Profit</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        var workerPay = booking.TotalWage * 0.90m;
                        var profit = booking.TotalWage - workerPay;
                        <tr>
                            <td>@booking.Client?.FirstName @booking.Client?.LastName</td>
                            <td>@booking.Worker?.FirstName @booking.Worker?.LastName</td>
                            <td>@booking.BookingDate.ToShortDateString()</td>
                            <td>@Math.Round((booking.EndTime - booking.StartTime).TotalHours, 2) hours</td>
                            <td>@booking.TaskDescription</td>
                            <td><strong>$@booking.TotalWage.ToString("F2")</strong></td>
                            <td>$@workerPay.ToString("F2")</td>
                            <td>$@profit.ToString("F2")</td>
                            <td>
                                @switch (booking.Status)
                                {
                                    case WorkerBookingSystem.Models.BookingStatus.Pending:
                                        <span class="badge bg-warning">Pending</span>
                                        break;
                                    case WorkerBookingSystem.Models.BookingStatus.Confirmed:
                                        <span class="badge bg-info">Confirmed</span>
                                        break;
                                    case WorkerBookingSystem.Models.BookingStatus.InProgress:
                                        <span class="badge bg-primary">In Progress</span>
                                        break;
                                    case WorkerBookingSystem.Models.BookingStatus.Completed:
                                        <span class="badge bg-success">Completed</span>
                                        break;
                                    case WorkerBookingSystem.Models.BookingStatus.Cancelled:
                                        <span class="badge bg-danger">Cancelled</span>
                                        break;
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No bookings in the selected date range.</div>
    }

    <div class="mt-3">
        <a href="@Url.Action("Dashboard")" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
