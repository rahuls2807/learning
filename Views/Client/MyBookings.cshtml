@model IEnumerable<WorkerBookingSystem.Models.Booking>

@{
    ViewData["Title"] = "My Bookings";
}

<div class="container mt-5">
    <h2>My Bookings</h2>

    @if (TempData["PaymentMessage"] != null)
    {
        <div class="alert alert-success">@TempData["PaymentMessage"]</div>
    }
    @if (TempData["BookingMessage"] != null)
    {
        <div class="alert alert-info">@TempData["BookingMessage"]</div>
    }

    <a href="@Url.Action("BookWorker")" class="btn btn-primary mb-3">+ Book Another Worker</a>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Worker</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Task</th>
                        <th>Total Wage</th>
                        <th>Paid Online</th>
                        <th>Paid to Worker</th>
                        <th>Balance</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        var balance = booking.TotalWage - booking.AmountPaidOnline - booking.AmountPaidToWorker;
                        <tr>
                            <td>@booking.Worker?.FirstName @booking.Worker?.LastName</td>
                            <td>@booking.Worker?.Email</td>
                            <td>@booking.Worker?.PhoneNumber</td>
                            <td>@booking.BookingDate.ToShortDateString()</td>
                            <td>@booking.StartTime.ToShortTimeString() - @booking.EndTime.ToShortTimeString()</td>
                            <td>@booking.TaskDescription</td>
                            <td>$@booking.TotalWage.ToString("F2")</td>
                            <td>$@booking.AmountPaidOnline.ToString("F2")</td>
                            <td>$@booking.AmountPaidToWorker.ToString("F2")</td>
                            <td>$@Math.Max(balance, 0).ToString("F2")</td>
                            <td>@booking.PaymentStatus</td>
                            <td>
                                @switch (booking.Status)
                                {
                                    case WorkerBookingSystem.Models.BookingStatus.Pending:
                                        <span class="badge bg-warning">Pending</span>
                                        break;
                                    case WorkerBookingSystem.Models.BookingStatus.Confirmed:
                                        <span class="badge bg-info">Confirmed</span>
                                        break;
                                    case WorkerBookingSystem.Models.BookingStatus.InProgress:
                                        <span class="badge bg-primary">In Progress</span>
                                        break;
                                    case WorkerBookingSystem.Models.BookingStatus.Completed:
                                        <span class="badge bg-success">Completed</span>
                                        break;
                                    case WorkerBookingSystem.Models.BookingStatus.Cancelled:
                                        <span class="badge bg-danger">Cancelled</span>
                                        break;
                                }
                            </td>
                            <td>
                                <div class="d-grid gap-2" style="min-width: 260px;">
                                @if (balance > 0)
                                {
                                    <a asp-controller="Payment" asp-action="Pay" asp-route-bookingId="@booking.BookingId" class="btn btn-sm btn-success">Pay</a>
                                    <form asp-action="RecordCashPayment" method="post" class="d-flex gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="BookingId" value="@booking.BookingId" />
                                        <input type="number" name="AmountPaidToWorker" class="form-control form-control-sm" min="0.01" max="@balance" step="0.01" placeholder="Cash paid" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Record</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">Paid</span>
                                }
                                    <form asp-action="UpdateBookingStatus" method="post" class="d-flex gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="BookingId" value="@booking.BookingId" />
                                        <select name="Status" class="form-select form-select-sm">
                                            <option value="1">Confirmed</option>
                                            <option value="2">In Progress</option>
                                            <option value="3">Completed</option>
                                            <option value="4">Cancelled</option>
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
                                    </form>
                                    @if (!string.IsNullOrWhiteSpace(booking.ClientStatusNote))
                                    {
                                        <small class="text-muted">@booking.ClientStatusNote</small>
                                    }
                                    @if (booking.Worker != null)
                                    {
                                        <a asp-controller="Worker" asp-action="Details" asp-route-id="@booking.WorkerId" class="btn btn-sm btn-outline-primary">Profile & Review</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">You haven't booked any workers yet. <a href="@Url.Action("BookWorker")">Book a worker now</a></div>
    }

    <div class="mt-3">
        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Back to Home</a>
    </div>
</div>
