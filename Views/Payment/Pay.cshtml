@model WorkerBookingSystem.Models.ViewModels.PaymentViewModel

@{
    ViewData["Title"] = "Secure Payment";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2>Secure Payment</h2>
            <div class="alert alert-info">
                Pay <strong>$@Model.Amount.ToString("F2")</strong> for your booking with @Model.WorkerName.
            </div>

            <form asp-action="Pay" method="post" autocomplete="off">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="BookingId" />

                <div class="form-group mb-3">
                    <label asp-for="CardholderName" class="control-label"></label>
                    <input asp-for="CardholderName" class="form-control" />
                    <span asp-validation-for="CardholderName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CardNumber" class="control-label"></label>
                    <input asp-for="CardNumber" class="form-control" inputmode="numeric" autocomplete="off" />
                    <span asp-validation-for="CardNumber" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Expiry" class="control-label"></label>
                            <input asp-for="Expiry" class="form-control" placeholder="MM/YY" autocomplete="off" />
                            <span asp-validation-for="Expiry" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Cvv" class="control-label"></label>
                            <input asp-for="Cvv" class="form-control" inputmode="numeric" autocomplete="off" />
                            <span asp-validation-for="Cvv" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <p class="text-muted small">Card details are validated for this payment only and are not stored.</p>

                <button type="submit" class="btn btn-success">Pay Now</button>
                <a asp-controller="Client" asp-action="MyBookings" class="btn btn-secondary">Pay Later</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
