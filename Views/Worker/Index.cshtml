@model IEnumerable<WorkerBookingSystem.Models.Worker>

@{
    ViewData["Title"] = "Workers";
    var workerRates = ViewBag.WorkerRates as Dictionary<int, decimal> ?? new Dictionary<int, decimal>();
}

<div class="container mt-5">
    <h2>Workers List</h2>
    
    <a asp-action="Create" class="btn btn-primary mb-3">+ Register New Worker</a>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Skill</th>
                        <th>Your Rate</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var worker in Model)
                    {
                        <tr>
                            <td>@worker.FirstName @worker.LastName</td>
                            <td>@worker.Email</td>
                            <td>@worker.PhoneNumber</td>
                            <td>@worker.Skill</td>
                            <td>
                                @if (workerRates.TryGetValue(worker.WorkerId, out var rate))
                                {
                                    <span>$@rate.ToString("F2")/hr</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td>
                                @if (worker.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@worker.WorkerId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="ManageAvailability" asp-route-id="@worker.WorkerId" class="btn btn-sm btn-info">Availability</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No workers registered yet.</div>
    }
</div>
